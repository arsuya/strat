# ====================================================================
# Bonus Stage Strat Detector — environment configuration
# ====================================================================
# Notification-only bot. Watches pools where the wallet has open DLMM
# positions and sends a Telegram alert when supertrend(10, 3) flips from
# GREEN to RED on a closed 15m candle.
#
# Safe to share TELEGRAM_BOT_TOKEN with strat_exit — this bot uses direct
# HTTP and does NOT long-poll Telegram.
# ====================================================================

# --- Solana RPC ---
RPC_URL=https://api.mainnet-beta.solana.com

# --- Wallet (pick ONE; MONITOR_ONLY_PUBKEY wins if both set) ---
# Public key only — no signing happens in this bot.
MONITOR_ONLY_PUBKEY=
# OR a base58 / JSON-array private key. The pubkey will be derived from it
# (this exists only so you can reuse strat_exit's .env file).
WALLET_PRIVATE_KEY=

# --- Telegram (leave blank to log notifications to stdout instead) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Pool filter (comma-separated pool addresses; blank = ALL pools) ---
POOL_FILTER=

# --- Supertrend parameters (user spec defaults) ---
SUPERTREND_LENGTH=10
SUPERTREND_FACTOR=3

# --- Behavior ---
# false = ONE notification per pool lifetime (default).
# true  = notify on EVERY green→red transition while positions are open.
REPEAT_NOTIFICATIONS=false

# --- Loop / persistence ---
POLL_INTERVAL_SECONDS=60
STATE_PATH=./state.json

# --- Advanced ---
# Path to the GeckoTerminal proxy script (must already exist on the VPS,
# installed by evilpanda-strat-detect). Leave default unless you've moved it.
# GT_PROXY_PATH=/home/ubuntu/evilpanda-strat-detect/gt_fetch.py
